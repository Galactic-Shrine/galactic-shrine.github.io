---
layout: layouts/base.njk
title: Standards de documentation
permalink: /standards/documentation/index.html
---
<section class="section page-header compact-header"><div class="container"><div class="section-head"><div><div class="eyebrow">Collection</div><h1>Standards de documentation</h1><p class="lead">Tous les standards de documentation Galactic-Shrine disponibles dans le portail.</p></div><div class="card-actions"><a class="button button-primary" href="/downloads/GalacticShrine-DocStandards-Harmonized-v1.2.0.zip">Télécharger le ZIP</a></div></div></div></section>
<section class="section"><div class="container"><div class="search-controls" style="margin-bottom:1rem;display:grid;grid-template-columns:2fr 1fr;gap:1rem;"><input type="search" data-filter-search placeholder="Rechercher dans cette section..." aria-label="Recherche locale"><select data-filter-category aria-label="Filtrer"><option value="all">Tous les éléments</option><option value="documentation">Documentation</option></select></div><p class="lead"><strong data-results-count>7</strong> élément(s)</p><div class="grid-3">{% for item in standards | whereCategory('documentation') %}<article class="doc-card" data-search-card data-category="{{ item.category }}" data-search="{{ item.title }} {{ item.summary }} {{ item.scope }} {{ (item.tags or []) | join(' ') }}"><div class="doc-meta"><span class="badge badge-accent">{{ item.categoryLabel }}</span><span class="badge">v{{ item.version }}</span></div><h3><a href="{{ item.htmlPath }}">{{ item.title }}</a></h3><p class="summary">{{ item.summary }}</p><div class="tag-list">{% for tag in item.tags %}
  {% if loop.index0 < 5 %}
    <span class="tag">{{ tag }}</span>
  {% endif %}
{% endfor %}</div><div class="card-actions"><a class="button small button-primary" href="{{ item.htmlPath }}">Lire</a>{% if item.rawPath %}<a class="button small" href="{{ item.rawPath }}">Markdown</a>{% endif %}</div></article>{% endfor %}</div><div class="empty-state" data-empty-state style="display:none;margin-top:1rem;">Aucun résultat pour ce filtre.</div></div></section>
